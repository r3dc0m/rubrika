extends ../layout

block content
    .form-container 
        .form-card
            span.form-title Crear cuenta
            span.form-subtitle
                | ¿Ya tienes una cuenta? 
                a(href="/auth/login") Inicia sesión

        form.form(
            action='/auth/register/profesor',
            method='POST'
            novalidate
        )

        // Nombre
        .form-group
            label(for='name') Nombre
            input#name(
                type='text', 
                name='name', required, 
                placeholder='Elsa'
                value=formData && formData.name ? formData.name : ''
                required
                min-lenght='2'
                max-lenght='50'
            )
            span.field-error(role='alert') #{errors && errors.name ? errors.name : ''}

        //Correo
        .form-group
          label(for='email') Correo electrónico
            span.required *
          input#email(
            type='email'
            name='email'
            placeholder='correo@correo.com'
            value=formData && formData.email
            required
            autocomplete='email'
          )
          span.field-error(role='alert') #{errors && errors.email ? errors.email : ''}

        //Contraseña
        .form-group
            label(for='password') Contraseña
                span.required *
            .input-password-wrapper
                input#password(
                    type='password'
                    name='password'
                    placeholder='Contraseña segura'
                    required
                    min-lenght='8'
                )
                span.field-hint
                    Usa al menos 8 caracteres, una mayúscula, un número y un símbolo.
                span.field-error(role='alert') #{errors && errors.password ? errors.password : ''}

        //Repetir contraseña
        .form-group
            label(for='confirmPassword') Repetir contraseña
                span.required *
            .input-password-wrapper
                input#confirmPassword(
                    type='password'
                    name='confirmPassword'
                    placeholder='Repetir contraseña'
                    required
                    min-lenght='8'
                )
                span.field-error(role='alert') #{errors && errors.confirmPassword ? errors.confirmPassword : ''}
                name='password'
                placeholder='Contraseña segura'
                required
                min-lenght='8'
            span.field-hint
                Usa al menos 8 caracteres, una mayúscula, un número y un símbolo.
            span.field-error(role='alert') #{errors && errors.password ? errors.password : ''}
            
            //Términos y condiciones
        .form-group.form-group--checkbox
            label.checkbox-label
                input#terminos(
                    type='checkbox', 
                    name='terms', 
                    required
                    checked=formData && formData.terms ? 'checked' : false
                    )
                span.checkmark(aria-hidden="true")
                span.checkbox-text
                    Acepto los
                a(href="#", target="_blank" rel='noopener noreferrer') términos y condiciones
                |&nbsp;y la&nbsp;
                a(href="#", target="_blank" rel='noopener noreferrer') política de privacidad
                span.required *
            span.field-error(role='alert') #{errors && errors.terms ? errors.terms : ''}

            // Mensaje de error general
        if errors && errors.general
            .form-error(role='alert') #{errors.general} 

        // Botón de envío
        button.btn.butn-primary(type='submit') Registrarse

        // Botón de cancelar
        button.btn.butn-primary(type='submit') Cancelar